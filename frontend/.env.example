# Base URL of the deployed backend extractor (Railway).
# No trailing slash; the frontend appends /extract and /batches.
VITE_EXTRACTOR_URL=https://gig-buddy-production.up.railway.app

# Shared secret for /batches CRUD. Must match API_TOKEN on the Railway server.
# Generate something strong (e.g. `openssl rand -hex 32` or a UUID).
VITE_API_TOKEN=replace-with-a-long-random-string

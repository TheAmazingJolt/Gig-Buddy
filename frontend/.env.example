# Base URL of the deployed backend (Railway).
# No trailing slash; the frontend appends /auth, /batches, /expenses, /extract*.
VITE_EXTRACTOR_URL=https://gig-buddy-production.up.railway.app

# As of Phase 2 of auth (account-based), there is no shared client-side
# secret. Sessions are issued per-user by /auth/login and /auth/signup
# and stored in localStorage as `batchwise:authToken`.
